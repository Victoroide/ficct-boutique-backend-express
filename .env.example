NODE_ENV=development
PORT=8081
LOG_LEVEL=debug

# Database
DATABASE_URL=postgres://ficct:ficct@postgres:5432/ficct_documents

# JWT — verifies tokens signed by the Go core backend
JWT_PUBLIC_KEY_PATH=/app/.tools/keys/jwt_public_dev.pem
JWT_ISSUER=ficct-go
JWT_AUDIENCE=ficct-express
JWT_KEY_ID=dev-1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:19006

# Storage (MinIO locally, AWS S3 in prod). Bucket must be PRIVATE.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_BUCKET=ficct-documents
S3_ACCESS_KEY_ID=minio-access
S3_SECRET_ACCESS_KEY=minio-secret-change-me
S3_PRESIGN_EXPIRY_SECONDS=900
# Local MinIO does not have KMS, so leave SSE disabled for dev.
# Enable in production where the bucket has SSE-AES256/SSE-KMS.
S3_SERVER_SIDE_ENCRYPTION=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
